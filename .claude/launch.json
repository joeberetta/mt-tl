{
    "version": "0.0.1",
    "configurations": [
        {
            "name": "serve (mtproto server + demo app, in-process)",
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["workspace", "demo-eos-seed-app", "run", "serve"],
            "port": 8081,
            "autoPort": false
        },
        {
            "name": "studio (mt-tl API explorer dev)",
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["workspace", "@mt-tl/studio", "dev", "--port", "5174"],
            "port": 5174,
            "autoPort": false
        },
        {
            "name": "docs (docusaurus site)",
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["workspace", "mt-tl-docs", "run", "start", "--port", "3000", "--no-open"],
            "port": 3000,
            "autoPort": false
        }
    ]
}
