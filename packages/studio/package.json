{
    "name": "@mt-tl/studio",
    "version": "0.1.5",
    "type": "module",
    "description": "Self-hosted interactive explorer + playground for an MTProto TL schema — the \"Swagger/Redoc for MTProto\". Point it at your .tl layers, get a static doc site with a layer-aware reference, scenario guides and a try-it playground.",
    "license": "MIT",
    "author": "Joe Beretta",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/joeberetta/mt-tl.git",
        "directory": "packages/studio"
    },
    "homepage": "https://github.com/joeberetta/mt-tl/tree/master/packages/studio#readme",
    "bugs": "https://github.com/joeberetta/mt-tl/issues",
    "keywords": [
        "mtproto",
        "tl",
        "schema",
        "docs",
        "explorer",
        "playground"
    ],
    "bin": {
        "mt-tl-studio": "./dist/cli/cli.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "build:app": "vite build && rm -f dist/app/api.json dist/app/wire.json dist/app/scenarios.json dist/app/changelog.json dist/app/descriptions.json",
        "build:cli": "tsc -p tsconfig.cli.json",
        "build": "rm -rf dist && yarn build:app && yarn build:cli",
        "prepack": "yarn build",
        "typecheck": "tsc --noEmit && tsc -p tsconfig.cli.json --noEmit",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@mt-tl/tl": "workspace:*"
    },
    "devDependencies": {
        "@mt-tl/server": "workspace:*",
        "@mt-tl/testing": "workspace:*",
        "@noble/ciphers": "^1.0.0",
        "@noble/hashes": "^1.4.0",
        "@types/node": "^20.14.0",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@types/ws": "^8.5.10",
        "@vitejs/plugin-react": "^4.3.1",
        "marked": "^12.0.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.6.3",
        "vite": "^5.4.0",
        "vitest": "^2.1.8",
        "ws": "^8.18.0",
        "yaml": "^2.5.0"
    }
}
