{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "outDir": "dist/cli",
        "rootDir": "src/cli",
        "declaration": false,
        "types": ["node"]
    },
    "include": ["src/cli"]
}
