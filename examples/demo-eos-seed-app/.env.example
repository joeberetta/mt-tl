# ── demo-eos-seed-app configuration ─────────────────────────────────────────
# This app reads its env (the framework reads none). Copy to `.env` in this dir:
#   cp .env.example .env
# Local dev runs the app on the host against infra in this app's docker-compose.
# The compose maps Mongo→27017 and Redis→6380 on the host (6379 is often already
# taken), so the URLs below point at those.

# ── Gateway: carriers ───────────────────────────────────────────────────────
# Either carrier can be disabled with off/none/disabled (or omitted).
MTPROTO_WS_PORT=8081      # WebSocket clients (MTPROTO_PORT is an alias)
MTPROTO_TCP_PORT=8082     # legacy raw-TCP clients

# Default TL layer until a client negotiates one via invokeWithLayer
DEFAULT_LAYER=204

# Directory of .tl schema files. Leave unset — this app owns its schema
# (./schema, exported by src/schema.ts). Only set it (absolute path) to point the
# gateway at a different schema dir for an ad-hoc run.
# SCHEMA_DIR=
# SCHEMA_LAYERS_DIR=

# RSA private key (PEM) for the auth-key exchange. MUST be the key whose
# fingerprint clients have pinned (15945119819404307495) for wire-compat.
# Leave empty in dev to generate an ephemeral key (real clients will NOT connect).
RSA_PRIVATE_KEY_PATH=

# ⚠️ INSECURE — disable the inbound MTProto 2.0 msg_key integrity check. Keep unset
# (defaults to false → the check is ON). Set to "true" ONLY as a temporary interop
# shim for non-compliant clients that still compute msg_key the MTProto 1.0 way; it
# drops inbound ciphertext authentication. See docs/internals/msgkey-v1-quirk.md.
# DISABLE_MSG_KEY_CHECK=false

# Disable inbound sequence-number validation (bad_msg_notification codes 32/34/35).
# Keep unset (defaults to false → the check is ON: content-related messages need an
# odd, increasing seqno; pure service messages an even one). Set to "true" as an
# interop shim for a client that does not set seqno to spec.
# DISABLE_SEQNO_CHECK=false

# Trust an upstream proxy/LB for the client address: parse the PROXY protocol
# (v1/v2) on raw TCP and trust X-Forwarded-For on WebSocket. Surfaces as
# ctx.request.ip. Keep off when clients connect directly (both are spoofable).
# TRUST_PROXY=false

# ── Gateway: storage ────────────────────────────────────────────────────────
STORAGE_BACKEND=mongo                       # "memory" (no services) or "mongo"
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=mtproto
REDIS_URL=redis://127.0.0.1:6380

# Stable id of this gateway instance (presence routing). Defaults to hostname.
NODE_ID=

# ── Server-push updates ─────────────────────────────────────────────────────
# Off by default. When on, REDIS_URL is required (presence + the pub/sub bus).
UPDATES_ENABLED=false
PRESENCE_TTL_MS=60000

# ── Observability ───────────────────────────────────────────────────────────
# See docs/guide/observability.md.
LOG_LEVEL=info            # trace | debug | info | warn | error | silent
LOG_FORMAT=pretty         # pretty (dev) | json (ship to a log pipeline)
# Include Error.stack on error lines. Default: on for pretty, off for json.
# LOG_ERROR_STACK=false

# ── App ─────────────────────────────────────────────────────────────────────
# The server's EOS seed: signs/verifies the auth code in crypto.sendCode/sign*.
# REQUIRED. Keep secret; any consistent value works (clients echo server_sign
# back — it is not pinned).
CHAT_SERVER_SEED=

# help.getConfig payload knobs (what the client is told about this DC).
CONFIG_DC_IP=127.0.0.1
CONFIG_DC_PORT=8081
CONFIG_ME_URL_PREFIX=https://t.me/
# SERVER_CONFIG_JSON={"feature":"value"}    # returned by help.getServerConfig
